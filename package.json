{
  "name": "@securevision/browser",
  "version": "1.0.0",
  "description": "SecureVision AI — Chromium-based security browser",
  "author": "SecureVision AI",
  "private": true,
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "pnpm run build:electron && concurrently -k \"vite --port 5175\" \"wait-on http://localhost:5175 && cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:5175 electron .\"",
    "dev:renderer": "vite --port 5174 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build:electron": "vite build --ssr src/main/main.ts --outDir dist-electron --emptyOutDir false && tsc src/main/preload.ts --outDir dist-electron --target es2022 --moduleResolution node --module commonjs --skipLibCheck true",
    "build": "cross-env NODE_ENV=production vite build && pnpm run build:electron",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "publish:win": "pnpm run build && electron-builder --win --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "@securevision/security-core": "workspace:*",
    "@securevision/shared": "workspace:*",
    "@securevision/telemetry": "workspace:*",
    "@securevision/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "wait-on": "^8.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}
